# Required: Anthropic API key for content generation (/api/generate, /api/script)
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Optional: point the key at a gateway/proxy or region endpoint.
# Defaults to https://api.anthropic.com
ANTHROPIC_BASE_URL=

# Optional: Image search APIs (/api/images). Set at least one.
# Server-side names are preferred; NEXT_PUBLIC_* are accepted as fallbacks.
UNSPLASH_KEY=
PEXELS_KEY=
PIXABAY_KEY=

# Optional: invite gate for /api/verify (comma-separated codes)
ADMIN_CODES=
INVITE_CODES=
