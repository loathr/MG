# Required: Anthropic API key for content generation (/api/generate)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Image search APIs (/api/images) — used by the Studio Photos panel.
# Set at least one. These are read SERVER-SIDE only (never exposed to the
# browser). At least one of the three must be present or the Photos search
# returns "no image API keys configured".
UNSPLASH_KEY=
PEXELS_KEY=
PIXABAY_KEY=

# Legacy fallback names (still honored by app/api/images/route.js, but the
# server-side names above are preferred — NEXT_PUBLIC_* would ship the key to
# the client bundle):
# NEXT_PUBLIC_UNSPLASH_KEY=
# NEXT_PUBLIC_PEXELS_KEY=
# NEXT_PUBLIC_PIXABAY_KEY=

# ---------------------------------------------------------------------------
# NOTE on Claude Code web environments: setting these keys is necessary but not
# sufficient — the environment's network egress allowlist must also permit the
# provider + image-CDN hosts, or requests are blocked with
# `x-deny-reason: host_not_allowed`. Hosts to allow-list:
#   api.unsplash.com, images.unsplash.com
#   api.pexels.com, images.pexels.com
#   pixabay.com, cdn.pixabay.com
#   commons.wikimedia.org, upload.wikimedia.org
# See https://code.claude.com/docs/en/claude-code-on-the-web (network policy).
# ---------------------------------------------------------------------------
